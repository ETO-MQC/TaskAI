{
   "action": {
      "default_popup": "popup.html"
   },
   "background": {
      "mode": "module",
      "service_worker": "background.chrome.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "extension.chrome.user.js" ],
      "matches": [ "\u003Call_urls>" ]
   }, {
      "all_frames": true,
      "js": [ "pre.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "preInjected.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start",
      "world": "MAIN"
   } ],
   "description": "Watch video together",
   "icons": {
      "192": "./icon/android-icon-192x192.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "VideoTogether",
   "permissions": [ "storage", "unlimitedStorage" ],
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "3.0.23",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "vt.en-us.user.js", "vt.zh-cn.user.js", "vt.ja-jp.user.js", "preInjected.js" ]
   } ]
}
